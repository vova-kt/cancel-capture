# Runtime storage
DATA_DIR=./data
SQLITE_PATH=./data/catalog.sqlite3
MAX_UPLOAD_BYTES=104857600
MAX_IMAGE_PIXELS=80000000

# Telegram Bot API (the bot must be an administrator in the channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_USER_ID=
TELEGRAM_CHANNEL=@cancel_capture
TELEGRAM_MAX_DOWNLOAD_BYTES=20971520
# Set both only when using a local Bot API server.
TELEGRAM_BOT_API_BASE_URL=
TELEGRAM_BOT_API_FILE_URL=

# Telegram MTProto history importer
# Create an application at https://my.telegram.org/apps, then copy its numeric api_id and api_hash.
# These are user-account MTProto credentials, not the Telegram bot token above.
TG_API_ID=
TG_API_HASH=
# Phone number for that Telegram account, in international format (for example, +491234567890).
# The first import prompts for the Telegram login code and, when enabled, the 2FA password.
TG_PHONE=
# Keep the generated session file private; it authorizes access to the Telegram account.
TG_SESSION_PATH=./data/telegram/cancel_capture

# OpenAI is the first adapter. Each role can use a separate key, endpoint, model, and non-secret
# identity namespace. Custom endpoints get a hashed namespace automatically; set it explicitly when
# multiple URLs name the same deployment. Never put credentials in a namespace.
OPENAI_API_KEY=
VISION_PROVIDER=openai
VISION_API_KEY=
VISION_BASE_URL=
VISION_IDENTITY_NAMESPACE=
VISION_MODEL=gpt-5.6-terra
TEXT_PROVIDER=openai
TEXT_API_KEY=
TEXT_BASE_URL=
TEXT_IDENTITY_NAMESPACE=
TEXT_MODEL=gpt-5.6-terra
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_IDENTITY_NAMESPACE=
EMBEDDING_MODEL=text-embedding-3-small
# Optional for embedding models that support shortened vectors.
EMBEDDING_DIMENSIONS=
